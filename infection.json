{
    "$schema": "https://raw.githubusercontent.com/infection/infection/master/resources/schema.json",
    "source": {
        "directories": [
            "src"
        ],
        "excludes": [
            "config",
            "Facades",
            "Exceptions"
        ]
    },
    "mutators": {
        "@default": true,
        "CastInt": false,
        "DecrementInteger": {
            "ignore": [
                "Mikehins\\Cart\\Cart::condition"
            ]
        }
    },
    "logs": {
        "text": "infection.log"
    },
    "minMsi": 90,
    "minCoveredMsi": 90
}